# =============================================================================
# iZimate — Root Environment Variables (shared tooling only)
#
# Each app has its own .env.example — copy and fill in:
#   apps/api/.env.example      → apps/api/.env
#   apps/realtime/.env.example  → apps/realtime/.env
#   apps/mobile/.env.example    → apps/mobile/.env
#   apps/web/.env.example       → apps/web/.env.local
#   apps/workers/.env.example   → apps/workers/.env
# =============================================================================

# --- Neon (Postgres) — used by drizzle-kit migrations ---
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/izimate?sslmode=require
