# =============================================================================
# iZimate Environment Variables
# Copy to .env and fill in values
# =============================================================================

# --- Neon (Postgres) ---
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/izimate?sslmode=require

# --- Auth0 ---
AUTH0_DOMAIN=izimate.eu.auth0.com
AUTH0_AUDIENCE=https://api.izimate.com
AUTH0_CLIENT_ID_SPA=
AUTH0_CLIENT_ID_NATIVE=
AUTH0_CLIENT_SECRET=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=izimate-uploads
R2_PUBLIC_URL=

# --- Resend ---
RESEND_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Sentry DSNs ---
SENTRY_DSN_API=
SENTRY_DSN_REALTIME=
SENTRY_DSN_WORKERS=
SENTRY_DSN_MOBILE=
SENTRY_DSN_WEB=

# --- AWS (for local dev — Lambda/SQS/SNS/etc.) ---
AWS_REGION=eu-central-1
AWS_PROFILE=izimate
SNS_EVENTS_TOPIC_ARN=
SQS_EMAIL_QUEUE_URL=
SQS_PUSH_QUEUE_URL=

# --- Redis (ElastiCache — local dev uses localhost) ---
REDIS_URL=redis://localhost:6379

# --- Expo Push ---
EXPO_ACCESS_TOKEN=
