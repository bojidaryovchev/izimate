# =============================================================================
# API Server (Fastify on Lambda)
# Copy to .env and fill in values
# =============================================================================

# --- Neon (Postgres) ---
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/izimate?sslmode=require

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.izimate.com

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=izimate-uploads
R2_PUBLIC_URL=

# --- AWS (SNS/SQS — local dev) ---
AWS_REGION=eu-central-1
AWS_PROFILE=izimate
SNS_EVENTS_TOPIC_ARN=
SQS_EMAIL_QUEUE_URL=
SQS_PUSH_QUEUE_URL=

# --- Sentry ---
SENTRY_DSN=

# --- Server ---
PORT=3001
