{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"],
      "@izimate/shared": ["../../packages/shared/src"],
      "@izimate/shared/*": ["../../packages/shared/src/*"],
      "@izimate/api-client": ["../../packages/api-client/src"],
      "@izimate/api-client/*": ["../../packages/api-client/src/*"]
    }
  },
  "include": ["src", "index.ts", "app.config.js"],
  "exclude": ["node_modules", "dist", ".expo"]
}
