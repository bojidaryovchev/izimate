# =============================================================================
# Realtime Server (Fastify + Socket.io on Fargate)
# Copy to .env and fill in values
# =============================================================================

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://api.izimate.com

# --- Redis (ElastiCache — local dev uses localhost) ---
REDIS_URL=redis://localhost:6379

# --- Sentry ---
SENTRY_DSN=

# --- Server ---
PORT=3001
