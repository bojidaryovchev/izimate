# =============================================================================
# Web App (Next.js)
# Copy to .env.local and fill in values
# @auth0/nextjs-auth0 v4 reads AUTH0_* vars automatically
# =============================================================================

# --- Auth0 ---
AUTH0_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
AUTH0_BASE_URL=http://localhost:3001
AUTH0_ISSUER_BASE_URL=https://your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.izimate.com

# --- Public (available in browser) ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Sentry ---
SENTRY_DSN=
