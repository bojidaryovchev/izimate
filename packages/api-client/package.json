{
  "name": "@izimate/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./socket": {
      "types": "./dist/socket/index.d.ts",
      "import": "./dist/socket/index.js"
    },
    "./socket/hooks": {
      "types": "./dist/socket/hooks.d.ts",
      "import": "./dist/socket/hooks.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@izimate/shared": "workspace:*",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
